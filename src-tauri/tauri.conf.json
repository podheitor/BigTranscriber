{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BigTranscriber",
  "version": "0.1.0",
  "identifier": "com.heitor.bigtranscriber",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BigTranscriber",
        "width": 1040,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
