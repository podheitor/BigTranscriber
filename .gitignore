# Rust / Tauri build output
/src-tauri/target/
/src-tauri/gen/

# Machine-specific Vulkan build config (regenerated by scripts/build.sh)
/src-tauri/.cargo/config.toml

# Local Vulkan header SDK (fetched by scripts/build.sh)
/.vulkan-sdk/

# Speech models — large; fetch with scripts/get-model.sh
/models/*.bin

# Recorded sessions / transcripts
/recordings/*
!/recordings/.gitkeep

# Node (only if a JS bundler is ever added)
node_modules/

# Local package artifacts (built with makepkg / tauri)
*.pkg.tar.*
*.AppImage
*.deb

# Editor / OS cruft
*.swp
*~
.DS_Store
.idea/
.vscode/
